          ]
        }
      ],
      "source": [
        "# Generate chunks\n",
        "all_chunks = []\n",
        "\n",
        "for sample in dataset:\n",
        "    text = sample[\"article\"]\n",
        "    chunks = chunk_text(text, chunk_tokenizer)\n",
        "    all_chunks.extend(chunks)\n",
        "\n",
        "print(\"Total chunks:\", len(all_chunks))\n",
        "print(\"Example chunk:\\n\", all_chunks[0][:300])"
      ]
    },

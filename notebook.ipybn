      },
      "source": [
        "Define chunk-level summarization"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Shared generation function\n",
        "def generate_summary(text, tokenizer, model, max_input=1024, max_new_tokens=200):\n",
        "    inputs = tokenizer(\n",
        "        text,\n",
        "        return_tensors=\"pt\",\n",
        "        truncation=True,\n",
        "        max_length=max_input\n",
        "    ).to(model.device)\n",
        "\n",
        "    outputs = model.generate(\n",
        "        **inputs,\n",
        "        max_new_tokens=max_new_tokens,\n",
        "        num_beams=4,\n",
        "        repetition_penalty=1.5,\n",
        "        no_repeat_ngram_size=3,\n",
        "        length_penalty=1.5,\n",
        "        early_stopping=True\n",
        "    )\n",
        "\n",
        "    return tokenizer.decode(outputs[0], skip_special_tokens=True)\n"
      ],
      "metadata": {
        "id": "WmS1FFoeUw27"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "XPGUKq1wtxoU"
      },
      "source": [
        "cleaning function as biobart tends to generate artifacts"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "hQQlMwDHtzB6"
      },
      "outputs": [],
      "source": [
        "def clean_summary(text):\n",
        "    text = re.sub(r'[¯_]{2,}', '', text)\n",
        "    text = re.sub(r'\\s([,\\.\\;\\:])', r'\\1', text)\n",
        "    text = re.sub(r'\\[\\s*\\d+\\s*\\]', '', text)\n",
        "    text = re.sub(r'\\s+', ' ', text).strip()\n",
        "    return text"
      ]
    },
